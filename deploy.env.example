# Copy this file to .deploy.env and adjust the values for your machine/server.

# SSH target used by ssh/rsync.
REMOTE_SSH_TARGET="pureapi"

# Server layout.
REMOTE_BASE_DIR="/home/pureapi"
REMOTE_RELEASES_DIR="/home/pureapi/releases"
REMOTE_CURRENT_LINK="/home/pureapi/current"
REMOTE_SHARED_DIR="/home/pureapi/shared"

# Service and health check.
SERVICE_NAME="pureapi"
REMOTE_SYSTEMCTL_BIN="/usr/bin/systemctl"
HEALTHCHECK_URL="http://127.0.0.1:3000/api/status"
HEALTHCHECK_RETRIES="12"
HEALTHCHECK_INTERVAL="2"

# Release artifact naming.
BINARY_NAME="pureapi-server"

# Optional extra SSH flags, for example:
# SSH_OPTIONS="-i ~/.ssh/pureapi_ed25519"
SSH_OPTIONS=""
